# Telegram Bot Token (von @BotFather erhalten)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram User-ID des einzigen erlaubten Nutzers
# Eigene ID herausfinden: Nachricht an @userinfobot senden
TELEGRAM_ALLOWED_USER_ID=987654321

# --- LLM Provider (eine der beiden Optionen) ---

# Option A: Anthropic direkt (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: OpenRouter (https://openrouter.ai/) – überschreibt Anthropic wenn gesetzt
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hauptmodell für komplexe Aufgaben (Check-ins, Analyse, Tool-Calls)
# Bei OpenRouter z.B. "anthropic/claude-sonnet-4-6"
LLM_MODEL=claude-sonnet-4-6

# Leichtgewichtiges Modell für schnelle Aufgaben (Routing, Gedächtnis-Zusammenfassungen)
# Bei OpenRouter z.B. "anthropic/claude-haiku-4-5-20251001"
LITE_MODEL=claude-haiku-4-5-20251001

# Zeitzone für die Scheduler-Jobs (IANA Timezone-Format)
TIMEZONE=Europe/Berlin
